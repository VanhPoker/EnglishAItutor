# Optional. In Docker production, leave unset so the app uses ws(s)://<current-host>:7880.
# For Vercel or any HTTPS frontend, voice only works when this points to a valid wss:// LiveKit endpoint.
# This project currently falls back to wss://livekit.4.145.98.216.sslip.io when served over HTTPS.
VITE_LIVEKIT_URL=ws://localhost:7880
