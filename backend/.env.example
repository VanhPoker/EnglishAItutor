# ===========================================
# English Agent — Environment Variables
# Copy this file to .env and fill in values
# ===========================================

MODE=dev

# --- LLM API Keys (at least one required) ---
# Primary: Google Gemini (free tier)
GOOGLE_API_KEY=

# Backup: Groq (free tier)
GROQ_API_KEY=

# Optional
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- LiveKit ---
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# --- PostgreSQL ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=english_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- mem0 (pgvector) ---
POSTGRES_MEM0_USER=postgres
POSTGRES_MEM0_PASSWORD=postgres
POSTGRES_MEM0_PORT=5432
POSTGRES_MEM0_DB=localhost

# --- LangChain Tracing (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=english-agent

# --- Frontend Chat Topic ---
FE_CHAT_TOPIC=ai-text-stream
